generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String
  balance   Decimal @default(0.0) @db.Decimal(10,2)
  role      Role    @default(USER)

  rentals Rental[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Bike {
  
  id         String @id @default(uuid())
  model      String
  brand      String
  year       Int
  
  dailyRate   Decimal @db.Decimal(10,2)
  weeklyRate  Decimal @db.Decimal(10,2)
  monthlyRate Decimal @db.Decimal(10,2)

  status     BikeStatus @default(AVAILABLE)

  rentals Rental[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bikes")
}

model Rental {
  id     String @id @default(uuid())
  userId String
  bikeId String

  plan       RentalPlan
  periods    Int
  totalPrice Decimal @db.Decimal(10,2)

  startDate          DateTime @default(now())
  expectedReturnDate DateTime
  actualReturnDate   DateTime?

  status     RentalStatus @default(ACTIVE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bike Bike @relation(fields: [bikeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bikeId])
  @@index([status])
  
  @@map("rentals")
}

model CompanyCash {
  id String @id @default(uuid())
  balance Decimal @default(0.0) @db.Decimal(10,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_cash")
}

enum Role {
  USER
  ADMIN
}

enum BikeStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum RentalStatus {
  ACTIVE
  WAITING_RETURN
  FINISHED
  CANCELED
  OVERDUE
}

enum RentalPlan {
  DAILY
  WEEKLY
  MONTHLY
}